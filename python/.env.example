# Notion
NOTION_API_KEY=your_notion_api_key_here
NOTION_INBOX_DB_ID=81c6e06c-3979-4922-a591-58dd1cd46b34
NOTION_REPORT_DB_ID=34da3bd9-3958-8007-82ee-efb717e2658f

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Calendar OAuth2
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

# 제외할 캘린더 (쉼표 구분, 빈칸이면 전체 포함)
CALENDAR_EXCLUDE=

# 분석 기준 날짜 (비우면 오늘 기준 이번 주, 예: 2026-05-06)
REPORT_DATE=
